# Copy to .env and fill in real values before running `docker compose up`

# --- Database ---
DB_NAME=medigenius
DB_USER=medigenius_user
DB_PASSWORD=medigenius_pass
MYSQL_ROOT_PASSWORD=change_me_root_password

# --- LLM provider: openai | groq | ollama ---
# "openai" is the default and points at OpenRouter's OpenAI-compatible API.
LLM_PROVIDER=openai
LLM_MODEL_NAME=deepseek/deepseek-r1-0528:free
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GROQ_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

# --- Tavily fallback search ---
TAVILY_API_KEY=your_tavily_api_key_here

# --- Vector store ---
# In-memory (LangChain4j InMemoryEmbeddingStore) - no config needed, no Docker required.

# --- Security ---
# Must be at least 32 bytes for HS256 signing
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_BYTES

# --- User Authentication (Feature 1/3) - separate secret from JWT_SECRET above ---
AUTH_JWT_SECRET=CHANGE_ME_TO_ANOTHER_LONG_RANDOM_SECRET_AT_LEAST_32_BYTES
AUTH_JWT_EXPIRATION_MS=86400000
PDF_UPLOAD_DIR=./uploads

# --- CORS ---
CORS_ALLOWED_ORIGINS=*

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
